# Keep this file free of real secrets. Copy it to .env on the server.
# Set either the plaintext code or its SHA-256 hash, not both.
MEMBERSHIP_ACCESS_CODE=
MEMBERSHIP_ACCESS_CODE_SHA256=

# Create these hosted links in GoDaddy Payments. The donation link should
# allow the customer to choose the payment amount.
GODADDY_PLUS_CHECKOUT_URL=
GODADDY_PLUSPLUS_CHECKOUT_URL=
GODADDY_DONATION_CHECKOUT_URL=

# Configure verification delivery on the production server.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=noreply@apotheosischurch.org
